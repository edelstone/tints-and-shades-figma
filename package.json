{
  "name": "tint-and-shade-generator",
  "version": "1.0.0",
  "description": "Instantly generate clean, structured tint and shade palettes from one or more hex colors directly inside Figma.",
  "main": "code.js",
  "homepage": "https://www.figma.com/community/plugin/1580658889126377365",
  "repository": {
    "type": "git",
    "url": "https://github.com/edelstone/tints-and-shades-figma.git"
  },
  "bugs": {
    "url": "https://github.com/edelstone/tints-and-shades-figma/issues",
    "email": "contact@maketintsandshades.com"
  },
  "keywords": [
    "figma",
    "figma-plugin",
    "color",
    "tint",
    "shade",
    "palette",
    "design-system",
    "design-tokens"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "lint": "eslint --ext .ts,.tsx --ignore-pattern node_modules .",
    "lint:fix": "eslint --ext .ts,.tsx --ignore-pattern node_modules --fix .",
    "test": "node --test test/*.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "watch": "node esbuild.config.mjs --watch"
  },
  "author": "Michael Edelstone",
  "license": "MIT",
  "devDependencies": {
    "@figma/eslint-plugin-figma-plugins": "*",
    "@figma/plugin-typings": "^1.121.0",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "@edelstone/tints-and-shades": "latest",
    "esbuild": "^0.25.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.2"
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended",
      "plugin:@figma/figma-plugins/recommended"
    ],
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
      "project": "./tsconfig.json"
    },
    "root": true,
    "rules": {
      "@typescript-eslint/no-unused-vars": [
        "error",
        {
          "argsIgnorePattern": "^_",
          "varsIgnorePattern": "^_",
          "caughtErrorsIgnorePattern": "^_"
        }
      ]
    }
  }
}
